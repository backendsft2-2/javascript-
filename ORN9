<body>
    <!--Elemanların Niteliğini Değiştirme ( setAttribute )
    HTML etiketinin niteliliğini değiştirmek için ilk olarak elemente ulaşmak
    gerekmektedir. Elemente ulaştıktan sonra setAttribute kullanılarak
    elementin niteliği değiştirilir-->
    <a href="https://google.com" class="a">Google</a>
    <a href="https://google.com" class="a">youtube</a>
    <a href="https://google.com" class="a">habertürk</a>
    <script>
        var a = document.getElementsByClassName("a");
        a[0].setAttribute("href", "https://www.fbu.edu.tr/");
        a[1].setAttribute("href", "https://www.fbu.edu.tr/");
        a[2].setAttribute("href", "https://www.fbu.edu.tr/");
    </script>
